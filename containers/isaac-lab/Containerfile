ARG ISAAC_LAB_BASE_IMAGE=nvcr.io/nvidia/isaac-sim:5.1.0
FROM ${ISAAC_LAB_BASE_IMAGE}

ARG JWST_IMAGE_VERSION=dev
LABEL org.opencontainers.image.title="jwst-isaac-lab"
LABEL org.opencontainers.image.version="${JWST_IMAGE_VERSION}"
LABEL org.opencontainers.image.description="JWST-Inspect Isaac Lab policy smoke runtime"

ENV JWST_CONTAINER_ROLE=isaac-lab \
    PYTHONUNBUFFERED=1

WORKDIR /opt/jwst/repo
COPY pyproject.toml README.md /opt/jwst/repo/
COPY src /opt/jwst/repo/src
COPY contracts /opt/jwst/repo/contracts
COPY configs /opt/jwst/repo/configs
COPY isaac_env /opt/jwst/repo/isaac_env
COPY evaluation /opt/jwst/repo/evaluation
COPY tests/fixtures /opt/jwst/repo/tests/fixtures

RUN if [ -x /isaac-sim/python.sh ]; then \
      /isaac-sim/python.sh -m pip install --no-cache-dir -e /opt/jwst/repo; \
    else \
      python -m pip install --no-cache-dir -e /opt/jwst/repo; \
    fi

ENTRYPOINT ["jwst-isaaclab-smoke"]
